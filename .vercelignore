# Vercel internals
.vercel
.git
.gitignore

# Dependencies
node_modules
# vendor (Biasanya sudah diabaikan oleh .gitignore bawaan Laravel)

# Environment variables (JANGAN di-upload, set di Vercel Dashboard)
.env
.env.example

# Tests & Dev files
tests/
phpunit.xml
phpunit.result.cache

# Storage & Logs (Sistem file Vercel bersifat Read-Only)
storage/*.key
storage/framework/cache/*
storage/framework/views/*
storage/framework/sessions/*
storage/logs/*
!storage/framework/cache/.gitignore
!storage/framework/views/.gitignore
!storage/framework/sessions/.gitignore

# Editor files
.idea
.vscode
*.sublime-workspace